{
  "info": {
    "_postman_id": "fincore-security-tests",
    "name": "FinCore Backend Security Tests",
    "description": "Security validation tests for protected role enforcement. Tests that ADMIN, SUPER_ADMIN, and SYSTEM_ADMINISTRATOR users cannot be created, modified, or deleted via API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "{{base_url}}",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "testUserId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authenticate First",
      "item": [
        {
          "name": "Request OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.devOtp) {",
                  "    pm.collectionVariables.set('otpCode', json Data.devOtp);",
                  "    console.log('OTP saved:', jsonData.devOtp);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/request-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "request-otp"]
            }
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('authToken', jsonData.token);",
                  "console.log('Auth token saved');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+1234567890\",\n  \"otp\": \"{{otpCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-otp"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Create User - Role Security",
      "item": [
        {
          "name": "✅ Create USER Role (Should Work)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Role is USER', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.role).to.eql('USER');",
                  "    pm.collectionVariables.set('testUserId', jsonData.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+1111111111\",\n  \"email\": \"test.user@fincore.com\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"dateOfBirth\": \"1995-01-01\",\n  \"statusDescription\": \"ACTIVE\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "✅ Create MANAGER Role (Should Work)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Role is MANAGER', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.role).to.eql('MANAGER');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+2222222222\",\n  \"email\": \"test.manager@fincore.com\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Manager\",\n  \"dateOfBirth\": \"1995-01-01\",\n  \"statusDescription\": \"ACTIVE\",\n  \"role\": \"MANAGER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "❌ Attempt ADMIN Role (Should Default to USER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Role is USER (NOT ADMIN)', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.role).to.eql('USER');",
                  "    pm.expect(jsonData.role).to.not.eql('ADMIN');",
                  "    console.log('✅ Security check passed: ADMIN role rejected, defaulted to USER');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+3333333333\",\n  \"email\": \"attempt.admin@fincore.com\",\n  \"firstName\": \"Attempt\",\n  \"lastName\": \"Admin\",\n  \"dateOfBirth\": \"1995-01-01\",\n  \"statusDescription\": \"ACTIVE\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "❌ Attempt SUPER_ADMIN Role (Should Default to USER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Role is USER (NOT SUPER_ADMIN)', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.role).to.eql('USER');",
                  "    pm.expect(jsonData.role).to.not.eql('SUPER_ADMIN');",
                  "    console.log('✅ Security check passed: SUPER_ADMIN role rejected, defaulted to USER');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+4444444444\",\n  \"email\": \"attempt.superadmin@fincore.com\",\n  \"firstName\": \"Attempt\",\n  \"lastName\": \"SuperAdmin\",\n  \"dateOfBirth\": \"1995-01-01\",\n  \"statusDescription\": \"ACTIVE\",\n  \"role\": \"SUPER_ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "❌ Attempt SYSTEM_ADMINISTRATOR Role (Should Default to USER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Role is USER (NOT SYSTEM_ADMINISTRATOR)', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.role).to.eql('USER');",
                  "    pm.expect(jsonData.role).to.not.eql('SYSTEM_ADMINISTRATOR');",
                  "    console.log('✅ Security check passed: SYSTEM_ADMINISTRATOR role rejected, defaulted to USER');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+5555555555\",\n  \"email\": \"attempt.sysadmin@fincore.com\",\n  \"firstName\": \"Attempt\",\n  \"lastName\": \"SysAdmin\",\n  \"dateOfBirth\": \"1995-01-01\",\n  \"statusDescription\": \"ACTIVE\",\n  \"role\": \"SYSTEM_ADMINISTRATOR\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Update User - Protected Role Security",
      "item": [
        {
          "name": "✅ Update Regular User (Should Work)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User updated successfully', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.firstName).to.eql('Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{testUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{testUserId}}"]
            }
          }
        },
        {
          "name": "❌ Attempt to Update Admin User (Should Fail with 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403 Forbidden', function() {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Error message mentions protected roles', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('protected roles');",
                  "    console.log('✅ Security check passed: Cannot update admin user');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Hacked\",\n  \"lastName\": \"Admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Attempt to update admin user (ID 1) - should return 403"
          }
        }
      ]
    },
    {
      "name": "4. Delete User - Protected Role Security",
      "item": [
        {
          "name": "✅ Delete Regular User (Should Work)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204 No Content', function() {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "console.log('✅ Regular user deleted successfully');"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{testUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{testUserId}}"]
            }
          }
        },
        {
          "name": "❌ Attempt to Delete Admin User (Should Fail with 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403 Forbidden', function() {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Error message mentions protected roles', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('protected roles');",
                  "    console.log('✅ Security check passed: Cannot delete admin user');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Attempt to delete admin user (ID 1) - should return 403"
          }
        }
      ]
    },
    {
      "name": "5. Get Users - Admin Filtering",
      "item": [
        {
          "name": "Get All Users (Should Filter Admin Users)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('No protected role users in response', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var protectedRoles = ['ADMIN', 'SUPER_ADMIN', 'SYSTEM_ADMINISTRATOR'];",
                  "    ",
                  "    jsonData.forEach(function(user) {",
                  "        pm.expect(protectedRoles).to.not.include(user.role);",
                  "    });",
                  "    ",
                  "    console.log('✅ Security check passed: Admin users filtered from list');",
                  "    console.log('Returned users count:', jsonData.length);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        }
      ]
    }
  ]
}
